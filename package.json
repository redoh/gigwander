{
  "name": "gigwander-api",
  "version": "1.0.0",
  "description": "GigWander - AI-driven concert trip planner API",
  "type": "module",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "start": "bun run src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "bun run src/db/seed.ts",
    "db:studio": "drizzle-kit studio",
    "check": "biome check src/",
    "format": "biome format --write src/",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.4.0",
    "@hono/zod-validator": "^0.2.2",
    "better-auth": "^1.2.0",
    "drizzle-orm": "^0.33.0",
    "drizzle-zod": "^0.5.1",
    "postgres": "^3.4.4",
    "zod": "^3.23.8",
    "openai": "^4.52.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.24.0",
    "@biomejs/biome": "^1.8.0",
    "typescript": "^5.5.0"
  }
}
